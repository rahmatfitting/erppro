generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

//////////////////////
// ENUMS
//////////////////////

enum BookingStatus {
  HOLD
  PENDING_PAYMENT
  PAID
  CONFIRMED
  CHECKED_IN
  COMPLETED
  CANCELLED
  EXPIRED
  FAILED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum VehicleStatus {
  ACTIVE
  MAINTENANCE
  INACTIVE
}

//////////////////////
// USERS & ROLES (CO-EXIST WITH CURRENT SYSTEM)
//////////////////////

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      String   // admin, staff, agen
  createdAt DateTime @default(now())

  bookings  Booking[]
}

//////////////////////
// CUSTOMER
//////////////////////

model Customer {
  id        String   @id @default(uuid())
  name      String
  phone     String
  email     String?
  createdAt DateTime @default(now())

  bookings  Booking[]
}

//////////////////////
// ROUTES & SCHEDULE
//////////////////////

model Route {
  id          String   @id @default(uuid())
  origin      String
  destination String
  createdAt   DateTime @default(now())

  schedules   Schedule[]
}

model Schedule {
  id          String   @id @default(uuid())
  routeId     String
  vehicleId   String
  driverId    String
  departure   DateTime
  price       Int
  createdAt   DateTime @default(now())

  route       Route    @relation(fields: [routeId], references: [id])
  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id])
  driver      Driver   @relation(fields: [driverId], references: [id])

  bookings    Booking[]

  @@index([routeId])
}

//////////////////////
// VEHICLE & DRIVER
//////////////////////

model Vehicle {
  id          String   @id @default(uuid())
  name        String
  plateNumber String   @unique
  capacity    Int
  status      VehicleStatus @default(ACTIVE)
  currentKm   Int      @default(0)
  layout      Json?    // Added for dynamic seat map configuration

  schedules   Schedule[]
  services    VehicleService[]
  serviceLogs ServiceLog[]
}

model Driver {
  id        String   @id @default(uuid())
  name      String
  phone     String
  createdAt DateTime @default(now())

  schedules Schedule[]
}

//////////////////////
// BOOKING
//////////////////////

model Booking {
  id          String        @id @default(uuid())
  code        String        @unique
  customerId  String
  scheduleId  String
  userId      String?
  status      BookingStatus @default(HOLD)
  expiredAt   DateTime?
  createdAt   DateTime      @default(now())

  customer    Customer @relation(fields: [customerId], references: [id])
  schedule    Schedule @relation(fields: [scheduleId], references: [id])
  user        User?    @relation(fields: [userId], references: [id])

  details     BookingDetail[]
  payment     Payment?

  @@index([scheduleId])
}

//////////////////////
// SEAT DETAIL (ANTI DOUBLE BOOKING)
//////////////////////

model BookingDetail {
  id          String  @id @default(uuid())
  bookingId   String
  seatNumber  Int

  booking     Booking @relation(fields: [bookingId], references: [id])

  // Hardcore protection: Unique seat per schedule
  // This ensures a seat cannot be held/booked twice for the same trip
  // Wait, I need scheduleId here too for the unique constraint to work effectively across different bookings
  scheduleId  String

  @@unique([scheduleId, seatNumber])
}

//////////////////////
// PAYMENT
//////////////////////

model Payment {
  id          String        @id @default(uuid())
  bookingId   String        @unique
  amount      Int
  method      String        // transfer, midtrans, dll
  status      PaymentStatus @default(PENDING)
  paidAt      DateTime?
  createdAt   DateTime      @default(now())
  proofImage  String?       // For manual transfer proof

  booking     Booking @relation(fields: [bookingId], references: [id])
}

//////////////////////
// MAINTENANCE (SERVIS)
//////////////////////

model ServiceType {
  id           String @id @default(uuid())
  name         String
  intervalKm   Int?
  intervalDays Int?

  services     VehicleService[]
  logs         ServiceLog[]
}

model VehicleService {
  id               String   @id @default(uuid())
  vehicleId        String
  serviceTypeId    String
  lastServiceKm    Int
  lastServiceDate  DateTime
  nextServiceKm    Int?
  nextServiceDate  DateTime?

  vehicle          Vehicle     @relation(fields: [vehicleId], references: [id])
  serviceType      ServiceType @relation(fields: [serviceTypeId], references: [id])
}

model ServiceLog {
  id          String   @id @default(uuid())
  vehicleId   String
  serviceTypeId String
  date        DateTime
  km          Int
  cost        Int
  notes       String?

  vehicle     Vehicle     @relation(fields: [vehicleId], references: [id])
  serviceType ServiceType @relation(fields: [serviceTypeId], references: [id])
}
