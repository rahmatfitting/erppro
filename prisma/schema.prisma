generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model buyback_prices {
  id           Int      @id @default(autoincrement())
  fetch_date   DateTime @unique(map: "fetch_date") @db.Date
  price_1g     Decimal  @db.Decimal(15, 2)
  prev_price   Decimal  @db.Decimal(15, 2)
  diff         Decimal  @db.Decimal(15, 2)
  last_updated DateTime @default(now()) @db.Timestamp(0)
}

model buyback_prices_history {
  id           Int      @id @default(autoincrement())
  fetch_date   DateTime @db.Date
  price_1g     Decimal  @db.Decimal(15, 2)
  prev_price   Decimal  @db.Decimal(15, 2)
  diff         Decimal  @db.Decimal(15, 2)
  last_updated DateTime @default(now()) @db.Timestamp(0)
  created_at   DateTime @default(now()) @db.Timestamp(0)
}

model crypto_divergence_signals {
  nomor         Int       @id @default(autoincrement())
  symbol        String    @unique(map: "symbol") @db.VarChar(20)
