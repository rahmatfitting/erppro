  tf_15m        String?   @db.VarChar(10)
  tf_1h         String?   @db.VarChar(10)
  tf_4h         String?   @db.VarChar(10)
  tf_1d         String?   @db.VarChar(10)
  macd_confirms Boolean?
  volume_spike  Boolean?
  created_at    DateTime? @default(now()) @db.DateTime(0)
}

model crypto_fvg_signals {
