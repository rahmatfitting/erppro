//////////////////////
// TRAVEL MANAGEMENT SYSTEM (TMS)
//////////////////////

enum TravelBookingStatus {
  HOLD
  PENDING_PAYMENT
  PAID
  CONFIRMED
  CHECKED_IN
  COMPLETED
  CANCELLED
  EXPIRED
  FAILED
  REFUNDED
}

enum TravelPaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum TravelVehicleStatus {
  ACTIVE
  MAINTENANCE
  INACTIVE
}

model TravelRoute {
  nomor       Int      @id @default(autoincrement())
  origin      String
  destination String
  createdAt   DateTime @default(now())

  schedules   TravelSchedule[]
}

model TravelSchedule {
  nomor       Int      @id @default(autoincrement())
  routeId     Int
  vehicleId   Int
  driverId    Int
  departure   DateTime
  price       Int
  createdAt   DateTime @default(now())

  route       TravelRoute    @relation(fields: [routeId], references: [nomor])
  vehicle     TravelVehicle  @relation(fields: [vehicleId], references: [nomor])
  driver      TravelDriver   @relation(fields: [driverId], references: [nomor])

  bookings    TravelBooking[]

  @@index([routeId])
}

model TravelVehicle {
  nomor       Int      @id @default(autoincrement())
  name        String
  plateNumber String   @unique
  capacity    Int
  status      TravelVehicleStatus @default(ACTIVE)
  currentKm   Int      @default(0)
  layout      Json?

  schedules   TravelSchedule[]
  services    TravelVehicleService[]
  serviceLogs TravelServiceLog[]
}

model TravelDriver {
  nomor     Int      @id @default(autoincrement())
  name      String
  phone     String
  createdAt DateTime @default(now())

  schedules TravelSchedule[]
}

model TravelBooking {
  nomor       Int        @id @default(autoincrement())
  code        String     @unique
  customerId  Int
  scheduleId  Int
  userId      Int?
  status      TravelBookingStatus @default(HOLD)
  expiredAt   DateTime?
  createdAt   DateTime   @default(now())

  customer    mhcustomer @relation(fields: [customerId], references: [nomor])
  schedule    TravelSchedule @relation(fields: [scheduleId], references: [nomor])
  user        mhuser?    @relation(fields: [userId], references: [nomor])

  details     TravelBookingDetail[]
  payment     TravelPayment?

  @@index([scheduleId])
}

model TravelBookingDetail {
  nomor       Int  @id @default(autoincrement())
  bookingId   Int
  seatNumber  Int
  scheduleId  Int

  booking     TravelBooking @relation(fields: [bookingId], references: [nomor])

  @@unique([scheduleId, seatNumber])
}

model TravelPayment {
  nomor       Int        @id @default(autoincrement())
  bookingId   Int        @unique
  amount      Int
  method      String     
  status      TravelPaymentStatus @default(PENDING)
  paidAt      DateTime?
  createdAt   DateTime   @default(now())
  proofImage  String?

  booking     TravelBooking @relation(fields: [bookingId], references: [nomor])
}

model TravelServiceType {
  nomor        Int @id @default(autoincrement())
  name         String
  intervalKm   Int?
  intervalDays Int?

  services     TravelVehicleService[]
  logs         TravelServiceLog[]
}

model TravelVehicleService {
  nomor            Int   @id @default(autoincrement())
  vehicleId        Int
  serviceTypeId    Int
  lastServiceKm    Int
  lastServiceDate  DateTime
  nextServiceKm    Int?
  nextServiceDate  DateTime?

  vehicle          TravelVehicle     @relation(fields: [vehicleId], references: [nomor])
  serviceType      TravelServiceType @relation(fields: [serviceTypeId], references: [nomor])
}

model TravelServiceLog {
  nomor         Int   @id @default(autoincrement())
  vehicleId     Int
  serviceTypeId Int
  date          DateTime
  km            Int
  cost          Int
  notes         String?

  vehicle          TravelVehicle     @relation(fields: [vehicleId], references: [nomor])
  serviceType      TravelServiceType @relation(fields: [serviceTypeId], references: [nomor])
}
